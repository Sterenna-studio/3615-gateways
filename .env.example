# 3615 Gateways runtime config

NODE_ENV=development

# HTTP server used for status, API and WebSocket upgrade
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# Telnet/BBS entrypoint used by ESP32 Telnet Pro in Telnet mode
TELNET_HOST=0.0.0.0
TELNET_PORT=3615

# WebSocket route used by ESP32 Telnet Pro in WebSocket mode
WS_PATH=/minitel/ws

# Public origin once exposed through Nitro / reverse proxy / tunnel
PUBLIC_ORIGIN=https://nitro.sterenna.fr

# Optional token for public WebSocket access. Leave empty for local MVP only.
GATEWAY_TOKEN=

# UI identity
GATEWAY_NAME=3615 GATEWAYS
GATEWAY_NODE=ZYRA
